<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="com.flipit.ui.panels.LoginPanel">
  <grid id="27dc6" binding="rootPanel" layout-manager="GridBagLayout">
    <constraints>
      <xy x="20" y="20" width="556" height="457"/>
    </constraints>
    <properties/>
    <border type="none"/>
    <children>
      <grid id="c6d10" binding="cardPanel" layout-manager="GridBagLayout">
        <constraints>
          <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
          <gridbag weightx="0.0" weighty="0.0"/>
        </constraints>
        <properties/>
        <border type="none"/>
        <children>
          <grid id="d214f" binding="header" layout-manager="FlowLayout" hgap="5" vgap="5" flow-align="1">
            <constraints>
              <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
              <gridbag weightx="0.0" weighty="0.0"/>
            </constraints>
            <properties/>
            <border type="none"/>
            <children>
              <component id="b5e3" class="javax.swing.JLabel" binding="titleLabel">
                <constraints/>
                <properties>
                  <text value="LOG IN"/>
                </properties>
              </component>
            </children>
          </grid>
          <component id="b7b1e" class="javax.swing.JLabel">
            <constraints>
              <grid row="1" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="0" fill="0" indent="0" use-parent-layout="false"/>
              <gridbag weightx="0.0" weighty="0.0"/>
            </constraints>
            <properties>
              <horizontalAlignment value="0"/>
              <horizontalTextPosition value="0"/>
              <text value="Sign in to your account"/>
            </properties>
          </component>
          <component id="450c3" class="javax.swing.JLabel" binding="usernameLabel">
            <constraints>
              <grid row="2" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
              <gridbag weightx="0.0" weighty="0.0"/>
            </constraints>
            <properties>
              <text value="Username"/>
            </properties>
          </component>
          <component id="14af7" class="javax.swing.JTextField" binding="usernameField">
            <constraints>
              <grid row="3" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="6" anchor="8" fill="1" indent="0" use-parent-layout="false">
                <preferred-size width="150" height="-1"/>
              </grid>
              <gridbag weightx="0.0" weighty="0.0"/>
            </constraints>
            <properties/>
          </component>
          <component id="b6ba5" class="javax.swing.JLabel" binding="passwordLabel">
            <constraints>
              <grid row="4" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
              <gridbag weightx="0.0" weighty="0.0"/>
            </constraints>
            <properties>
              <text value="Password"/>
            </properties>
          </component>
          <component id="b550e" class="javax.swing.JPasswordField" binding="passwordField">
            <constraints>
              <grid row="5" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="6" anchor="8" fill="1" indent="0" use-parent-layout="false">
                <preferred-size width="150" height="-1"/>
              </grid>
              <gridbag weightx="0.0" weighty="0.0"/>
            </constraints>
            <properties/>
          </component>
          <component id="eafc2" class="javax.swing.JLabel" binding="errorLabel">
            <constraints>
              <grid row="6" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
              <gridbag weightx="0.0" weighty="0.0"/>
            </constraints>
            <properties>
              <text value=""/>
            </properties>
          </component>
          <component id="51cac" class="javax.swing.JButton" binding="loginBtn">
            <constraints>
              <grid row="7" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
              <gridbag weightx="0.0" weighty="0.0"/>
            </constraints>
            <properties>
              <text value="Sign in"/>
            </properties>
          </component>
          <grid id="abd09" binding="footer" layout-manager="FlowLayout" hgap="5" vgap="5" flow-align="1">
            <constraints>
              <grid row="8" column="0" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
              <gridbag weightx="0.0" weighty="0.0"/>
            </constraints>
            <properties/>
            <border type="none"/>
            <children>
              <component id="1e47e" class="javax.swing.JLabel" binding="footerLabel">
                <constraints/>
                <properties>
                  <text value="Don't have an account?"/>
                </properties>
              </component>
              <component id="479cf" class="javax.swing.JButton" binding="signupBtn">
                <constraints/>
                <properties>
                  <text value="Create an account"/>
                </properties>
              </component>
            </children>
          </grid>
        </children>
      </grid>
    </children>
  </grid>
</form>
