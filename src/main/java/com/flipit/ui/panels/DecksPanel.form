<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="com.flipit.ui.panels.DecksPanel">
  <grid id="27dc6" binding="root" layout-manager="BorderLayout" hgap="0" vgap="0">
    <constraints>
      <xy x="20" y="20" width="650" height="400"/>
    </constraints>
    <properties/>
    <border type="none"/>
    <children>
      <grid id="hdrWrap" layout-manager="BorderLayout" hgap="0" vgap="0">
        <constraints border-constraint="North"/>
        <properties>
          <opaque value="false"/>
        </properties>
        <border type="none"/>
        <children>
          <grid id="eab1b" binding="topBarPanel" layout-manager="GridBagLayout">
            <constraints border-constraint="North"/>
            <properties>
              <preferredSize width="-1" height="65"/>
            </properties>
            <border type="empty">
              <size top="5" left="5" bottom="5" right="5"/>
            </border>
            <children>
              <grid id="5d19" binding="searchPanel" layout-manager="GridBagLayout">
                <constraints>
                  <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="7" anchor="8" fill="1" indent="0" use-parent-layout="false"/>
                  <gridbag top="0" left="0" bottom="0" right="16" weightx="1.0" weighty="0.0"/>
                </constraints>
                <properties>
                  <preferredSize width="-1" height="50"/>
                </properties>
                <border type="none"/>
                <children>
                  <component id="efc1f" class="javax.swing.JLabel" binding="searchLabel">
                    <constraints>
                      <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
                      <gridbag top="0" left="0" bottom="0" right="6" weightx="0.0" weighty="0.0"/>
                    </constraints>
                    <properties>
                      <text value=""/>
                    </properties>
                  </component>
                  <component id="c929b" class="javax.swing.JTextField" binding="searchField">
                    <constraints>
                      <grid row="0" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="6" anchor="8" fill="1" indent="0" use-parent-layout="false"/>
                      <gridbag weightx="1.0" weighty="0.0"/>
                    </constraints>
                    <properties>
                      <preferredSize width="74" height="48"/>
                    </properties>
                  </component>
                </children>
              </grid>
              <component id="74832" class="javax.swing.JComboBox" binding="sortComboBox">
                <constraints>
                  <grid row="0" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="1" indent="0" use-parent-layout="false"/>
                  <gridbag top="0" left="0" bottom="0" right="8" weightx="0.0" weighty="0.0"/>
                </constraints>
                <properties>
                  <preferredSize width="162" height="50"/>
                </properties>
              </component>
              <component id="refBtn" class="javax.swing.JButton" binding="refreshButton">
                <constraints>
                  <grid row="0" column="2" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="1" indent="0" use-parent-layout="false"/>
                  <gridbag top="0" left="0" bottom="0" right="12" weightx="0.0" weighty="0.0"/>
                </constraints>
                <properties>
                  <preferredSize width="50" height="50"/>
                  <text value=""/>
                </properties>
              </component>
              <component id="805e7" class="javax.swing.JButton" binding="addDeckBtn">
                <constraints>
                  <grid row="0" column="3" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="4" fill="0" indent="0" use-parent-layout="false"/>
                  <gridbag weightx="0.0" weighty="0.0"/>
                </constraints>
                <properties>
                  <preferredSize width="130" height="50"/>
                  <text value="ADD DECK"/>
                </properties>
              </component>
            </children>
          </grid>
          <grid id="tabPanelGrid" binding="tabPanel" layout-manager="FlowLayout" hgap="12" vgap="0" flow-align="0">
            <constraints border-constraint="South"/>
            <properties>
              <opaque value="false"/>
            </properties>
            <border type="empty">
              <size top="0" left="10" bottom="5" right="10"/>
            </border>
            <children>
              <component id="tabMy" class="javax.swing.JButton" binding="myDecksTab">
                <constraints/>
                <properties>
                  <text value="My Decks"/>
                </properties>
              </component>
              <component id="tabSaved" class="javax.swing.JButton" binding="savedDecksTab">
                <constraints/>
                <properties>
                  <text value="Saved Decks"/>
                </properties>
              </component>
            </children>
          </grid>
        </children>
      </grid>
      <scrollpane id="9408">
        <constraints border-constraint="Center"/>
        <properties/>
        <border type="none"/>
        <children>
          <grid id="92578" binding="gridWrapperPanel" layout-manager="BorderLayout" hgap="0" vgap="0">
            <constraints/>
            <properties/>
            <border type="empty"/>
            <children>
              <grid id="c55fb" binding="deckGridPanel" layout-manager="GridBagLayout">
                <constraints border-constraint="North"/>
                <properties/>
                <border type="none"/>
                <children/>
              </grid>
            </children>
          </grid>
        </children>
      </scrollpane>
    </children>
  </grid>
</form>
