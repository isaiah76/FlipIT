<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="com.flipit.ui.panels.CardEditorPanel">
  <grid id="27dc6" binding="root" layout-manager="BorderLayout" hgap="0" vgap="0">
    <constraints>
      <xy x="20" y="20" width="500" height="400"/>
    </constraints>
    <properties/>
    <border type="none"/>
    <children>
      <grid id="ea0cc" binding="headerPanel" layout-manager="GridBagLayout">
        <constraints border-constraint="North"/>
        <properties>
          <background color="-16777216"/>
        </properties>
        <border type="empty"/>
        <children>
          <component id="20e21" class="javax.swing.JButton" binding="backBtn">
            <constraints>
              <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
              <gridbag weightx="0.0" weighty="0.0"/>
            </constraints>
            <properties>
              <text value="← Back"/>
            </properties>
          </component>
          <component id="39d" class="javax.swing.JLabel" binding="deckTitle">
            <constraints>
              <grid row="1" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="7" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
              <gridbag weightx="1.0" weighty="0.0"/>
            </constraints>
            <properties>
              <font size="14" style="1"/>
              <text value="Deck Title"/>
            </properties>
          </component>
          <component id="7136d" class="javax.swing.JButton" binding="addCardBtn">
            <constraints>
              <grid row="1" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="4" fill="0" indent="0" use-parent-layout="false"/>
              <gridbag weightx="0.0" weighty="0.0"/>
            </constraints>
            <properties>
              <preferredSize width="80" height="30"/>
              <text value="+ ADD CARD"/>
            </properties>
          </component>
        </children>
      </grid>
      <scrollpane id="ce677" binding="cardScrollPane">
        <constraints border-constraint="Center"/>
        <properties/>
        <border type="none"/>
        <children>
          <grid id="c1385" binding="cardListPanel" layout-manager="BorderLayout" hgap="0" vgap="0">
            <constraints/>
            <properties>
              <background color="-16777216"/>
            </properties>
            <border type="empty"/>
            <children/>
          </grid>
        </children>
      </scrollpane>
    </children>
  </grid>
</form>
