<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="com.flipit.ui.panels.admin.AdminDashboardPanel">
  <grid id="27dc6" binding="root" layout-manager="BorderLayout" hgap="0" vgap="0">
    <constraints>
      <xy x="20" y="20" width="700" height="500"/>
    </constraints>
    <properties/>
    <border type="none"/>
    <children>
      <scrollpane id="a8f3e" binding="scrollPane">
        <constraints border-constraint="Center"/>
        <properties>
          <horizontalScrollBarPolicy value="31"/>
        </properties>
        <border type="none"/>
        <children>
          <grid id="92578" binding="bodyPanel" layout-manager="FlowLayout" hgap="33" vgap="44" flow-align="1">
            <constraints/>
            <properties/>
            <border type="empty"/>
            <children/>
          </grid>
        </children>
      </scrollpane>
    </children>
  </grid>
</form>
