              </grid>
              <grid id="535fc" binding="sectionHeaderPanel" layout-manager="GridBagLayout">
                <constraints>
                  <grid row="1" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="7" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
                  <gridbag top="0" left="0" bottom="12" right="0" weightx="1.0" weighty="0.0"/>
