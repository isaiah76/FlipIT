<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="com.flipit.ui.panels.LoginPanel">
  <grid id="27dc6" binding="root" layout-manager="GridBagLayout">
    <constraints>
      <xy x="20" y="20" width="500" height="400"/>
    </constraints>
    <properties/>
    <border type="none"/>
    <children>
      <grid id="6f512" binding="cardPanel" layout-manager="GridBagLayout">
        <constraints>
          <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
          <gridbag weightx="0.0" weighty="0.0"/>
        </constraints>
        <properties/>
        <border type="none"/>
        <children>
          <grid id="4c3ab" binding="header" layout-manager="FlowLayout" hgap="5" vgap="5" flow-align="1">
            <constraints>
              <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
              <gridbag weightx="0.0" weighty="0.0"/>
            </constraints>
            <properties/>
            <border type="none"/>
            <children>
              <component id="98f12" class="javax.swing.JLabel" binding="titleLabel">
                <constraints/>
                <properties>
                  <text value="LOG IN"/>
                </properties>
              </component>
            </children>
          </grid>
          <component id="1a2b3" class="javax.swing.JLabel">
            <constraints>
              <grid row="1" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="0" fill="0" indent="0" use-parent-layout="false"/>
              <gridbag weightx="0.0" weighty="0.0"/>
            </constraints>
            <properties>
              <horizontalAlignment value="0"/>
              <horizontalTextPosition value="0"/>
              <text value="Sign in to your account"/>
            </properties>
          </component>
          <component id="3d4e5" class="javax.swing.JLabel" binding="usernameLabel">
            <constraints>
              <grid row="3" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
              <gridbag weightx="0.0" weighty="0.0"/>
            </constraints>
            <properties>
              <text value="Username"/>
            </properties>
          </component>
          <component id="5f6g7" class="javax.swing.JTextField" binding="usernameField">
            <constraints>
              <grid row="5" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="6" anchor="8" fill="1" indent="0" use-parent-layout="false"/>
              <gridbag weightx="0.0" weighty="0.0"/>
            </constraints>
            <properties/>
          </component>
          <component id="7h8i9" class="javax.swing.JLabel" binding="passwordLabel">
            <constraints>
              <grid row="7" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
              <gridbag weightx="0.0" weighty="0.0"/>
            </constraints>
            <properties>
              <text value="Password"/>
            </properties>
          </component>
          <grid id="pw123" binding="passwordWrapper" layout-manager="BorderLayout" hgap="0" vgap="0">
            <constraints>
              <grid row="8" column="0" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
              <gridbag weightx="0.0" weighty="0.0"/>
            </constraints>
            <properties>
              <background color="-1"/>
            </properties>
            <border type="none"/>
            <children>
              <component id="9j0k1" class="javax.swing.JPasswordField" binding="passwordField">
                <constraints border-constraint="Center"/>
                <properties/>
              </component>
              <component id="tgl1" class="javax.swing.JToggleButton" binding="togglePwdBtn">
                <constraints border-constraint="East"/>
                <properties>
                  <borderPainted value="false"/>
                  <contentAreaFilled value="false"/>
                  <focusPainted value="false"/>
                  <text value="👁"/>
                </properties>
              </component>
              <vspacer id="be41d">
                <constraints border-constraint="North"/>
              </vspacer>
            </children>
          </grid>
          <component id="1l2m3" class="javax.swing.JLabel" binding="errorLabel">
            <constraints>
              <grid row="9" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
              <gridbag weightx="0.0" weighty="0.0"/>
            </constraints>
            <properties>
              <text value=" "/>
            </properties>
          </component>
          <component id="3n4o5" class="javax.swing.JButton" binding="loginBtn">
            <constraints>
              <grid row="10" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
              <gridbag weightx="0.0" weighty="0.0"/>
            </constraints>
            <properties>
              <text value="Sign in"/>
            </properties>
          </component>
          <grid id="5p6q7" binding="footer" layout-manager="FlowLayout" hgap="5" vgap="5" flow-align="1">
            <constraints>
              <grid row="12" column="0" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
              <gridbag weightx="0.0" weighty="0.0"/>
            </constraints>
            <properties/>
            <border type="none"/>
            <children>
              <component id="7r8s9" class="javax.swing.JLabel" binding="footerLabel">
                <constraints/>
                <properties>
                  <text value="Don't have an account?"/>
                </properties>
              </component>
              <component id="9t0u1" class="javax.swing.JButton" binding="signupBtn">
                <constraints/>
                <properties>
                  <text value="Create an account"/>
                </properties>
              </component>
            </children>
          </grid>
          <vspacer id="985b1">
            <constraints>
              <grid row="2" column="0" row-span="1" col-span="1" vsize-policy="6" hsize-policy="1" anchor="0" fill="2" indent="0" use-parent-layout="false"/>
              <gridbag weightx="0.0" weighty="0.0"/>
            </constraints>
          </vspacer>
          <vspacer id="a92d1">
            <constraints>
              <grid row="4" column="0" row-span="1" col-span="1" vsize-policy="6" hsize-policy="1" anchor="0" fill="2" indent="0" use-parent-layout="false"/>
              <gridbag weightx="0.0" weighty="0.0"/>
            </constraints>
          </vspacer>
          <vspacer id="e5987">
            <constraints>
              <grid row="6" column="0" row-span="1" col-span="1" vsize-policy="6" hsize-policy="1" anchor="0" fill="2" indent="0" use-parent-layout="false"/>
              <gridbag weightx="0.0" weighty="0.0"/>
            </constraints>
          </vspacer>
          <vspacer id="1e20b">
            <constraints>
              <grid row="11" column="0" row-span="1" col-span="1" vsize-policy="6" hsize-policy="1" anchor="0" fill="2" indent="0" use-parent-layout="false"/>
              <gridbag weightx="0.0" weighty="0.0"/>
            </constraints>
          </vspacer>
        </children>
      </grid>
    </children>
  </grid>
</form>
