<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="com.flipit.ui.panels.QuizResultsPanel">
  <grid id="27dc6" binding="root" layout-manager="BorderLayout" hgap="0" vgap="0">
    <constraints>
      <xy x="20" y="20" width="914" height="450"/>
    </constraints>
    <properties>
      <opaque value="false"/>
    </properties>
    <border type="empty">
      <size top="25" left="38" bottom="25" right="38"/>
    </border>
    <children>
      <grid id="topBar" layout-manager="FlowLayout" hgap="0" vgap="0" flow-align="0">
        <constraints border-constraint="North"/>
        <properties>
          <opaque value="false"/>
        </properties>
        <border type="empty">
          <size top="0" left="0" bottom="15" right="0"/>
        </border>
        <children>
          <component id="back" class="javax.swing.JButton" binding="backBtn">
            <constraints/>
            <properties>
              <text value="Back"/>
            </properties>
          </component>
        </children>
      </grid>
      <grid id="wrap" layout-manager="BorderLayout" hgap="0" vgap="0">
        <constraints border-constraint="Center"/>
        <properties>
          <opaque value="false"/>
        </properties>
        <border type="none"/>
        <children>
          <grid id="card" binding="cardPanel" layout-manager="GridBagLayout">
            <constraints border-constraint="Center"/>
            <properties>
              <opaque value="false"/>
            </properties>
            <border type="none"/>
            <children>
              <grid id="blue" binding="bluePanel" layout-manager="GridBagLayout">
                <constraints>
                  <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
                  <gridbag weightx="0.35" weighty="1.0"/>
                </constraints>
                <properties>
                  <opaque value="false"/>
                </properties>
                <border type="empty">
                  <size top="30" left="30" bottom="30" right="30"/>
                </border>
                <children>
                  <grid id="blueInner" layout-manager="GridLayoutManager" row-count="3" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="4">
                    <margin top="0" left="0" bottom="0" right="0"/>
                    <constraints>
                      <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="0" indent="0" use-parent-layout="false"/>
                      <gridbag weightx="1.0" weighty="1.0"/>
                    </constraints>
                    <properties>
                      <opaque value="false"/>
                    </properties>
                    <border type="none"/>
                    <children>
                      <component id="hdr" class="javax.swing.JLabel" binding="resultsHeaderLbl">
                        <constraints>
                          <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
                        </constraints>
                        <properties>
                          <horizontalAlignment value="0"/>
                          <text value="QUIZ RESULTS"/>
                        </properties>
                      </component>
                      <component id="spct" class="javax.swing.JLabel" binding="mainScorePctLbl">
                        <constraints>
                          <grid row="1" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
                        </constraints>
                        <properties>
                          <horizontalAlignment value="0"/>
                          <text value="60%"/>
                        </properties>
                      </component>
                      <component id="ssub" class="javax.swing.JLabel" binding="mainScoreSubLbl">
                        <constraints>
                          <grid row="2" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
                        </constraints>
                        <properties>
                          <horizontalAlignment value="0"/>
                          <text value="SCORE"/>
                        </properties>
                      </component>
                    </children>
                  </grid>
                </children>
              </grid>
              <grid id="right" binding="rightPanel" layout-manager="BorderLayout" hgap="0" vgap="0">
                <constraints>
                  <grid row="0" column="1" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
                  <gridbag weightx="0.65" weighty="1.0"/>
                </constraints>
                <properties>
                  <opaque value="false"/>
                </properties>
                <border type="none"/>
                <children>
                  <grid id="statsWrapper" binding="statsWrapper" layout-manager="CardLayout" hgap="0" vgap="0">
                    <constraints border-constraint="Center"/>
                    <properties>
                      <opaque value="false"/>
                    </properties>
                    <border type="none"/>
                    <children>
                      <grid id="statsSkel" binding="statsSkeletonContainer" layout-manager="BorderLayout" hgap="0" vgap="0">
                        <constraints>
                          <card name="SKELETON"/>
                        </constraints>
                        <properties>
                          <opaque value="false"/>
                        </properties>
                        <border type="none"/>
                        <children/>
                      </grid>
                      <grid id="stats" binding="statsPanel" layout-manager="GridLayoutManager" row-count="1" column-count="3" same-size-horizontally="true" same-size-vertically="false" hgap="0" vgap="0">
                        <margin top="0" left="0" bottom="0" right="0"/>
                        <constraints>
                          <card name="CONTENT"/>
                        </constraints>
                        <properties>
                          <opaque value="false"/>
                        </properties>
                        <border type="none"/>
                        <children>
                          <grid id="cWrap" binding="correctPanel" layout-manager="GridLayoutManager" row-count="4" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="4">
                            <margin top="0" left="0" bottom="0" right="0"/>
                            <constraints>
                              <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
                            </constraints>
                            <properties>
                              <opaque value="false"/>
                            </properties>
                            <border type="none"/>
                            <children>
                              <vspacer id="cSpcTop">
                                <constraints>
                                  <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="6" hsize-policy="1" anchor="0" fill="2" indent="0" use-parent-layout="false"/>
                                </constraints>
                              </vspacer>
                              <component id="cVal" class="javax.swing.JLabel" binding="correctValLbl">
                                <constraints>
                                  <grid row="1" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
                                </constraints>
                                <properties>
                                  <horizontalAlignment value="0"/>
                                  <text value="6"/>
                                </properties>
                              </component>
                              <component id="cTitle" class="javax.swing.JLabel">
                                <constraints>
                                  <grid row="2" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
                                </constraints>
                                <properties>
                                  <horizontalAlignment value="0"/>
                                  <text value="CORRECT"/>
                                </properties>
                              </component>
                              <vspacer id="cSpcBot">
                                <constraints>
                                  <grid row="3" column="0" row-span="1" col-span="1" vsize-policy="6" hsize-policy="1" anchor="0" fill="2" indent="0" use-parent-layout="false"/>
                                </constraints>
                              </vspacer>
                            </children>
                          </grid>
                          <grid id="mWrap" binding="missedPanel" layout-manager="GridLayoutManager" row-count="4" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="4">
                            <margin top="0" left="0" bottom="0" right="0"/>
                            <constraints>
                              <grid row="0" column="1" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
                            </constraints>
                            <properties>
                              <opaque value="false"/>
                            </properties>
                            <border type="none"/>
                            <children>
                              <vspacer id="mSpcTop">
                                <constraints>
                                  <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="6" hsize-policy="1" anchor="0" fill="2" indent="0" use-parent-layout="false"/>
                                </constraints>
                              </vspacer>
                              <component id="mVal" class="javax.swing.JLabel" binding="missedValLbl">
                                <constraints>
                                  <grid row="1" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
                                </constraints>
                                <properties>
                                  <horizontalAlignment value="0"/>
                                  <text value="4"/>
                                </properties>
                              </component>
                              <component id="mTitle" class="javax.swing.JLabel">
                                <constraints>
                                  <grid row="2" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
                                </constraints>
                                <properties>
                                  <horizontalAlignment value="0"/>
                                  <text value="MISSED"/>
                                </properties>
                              </component>
                              <vspacer id="mSpcBot">
                                <constraints>
                                  <grid row="3" column="0" row-span="1" col-span="1" vsize-policy="6" hsize-policy="1" anchor="0" fill="2" indent="0" use-parent-layout="false"/>
                                </constraints>
                              </vspacer>
                            </children>
                          </grid>
                          <grid id="bContent" binding="bestContentPanel" layout-manager="GridLayoutManager" row-count="4" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="4">
                            <margin top="0" left="0" bottom="0" right="0"/>
                            <constraints>
                              <grid row="0" column="2" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
                            </constraints>
                            <properties>
                              <opaque value="false"/>
                            </properties>
                            <border type="none"/>
                            <children>
                              <vspacer id="bSpcTop">
                                <constraints>
                                  <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="6" hsize-policy="1" anchor="0" fill="2" indent="0" use-parent-layout="false"/>
                                </constraints>
                              </vspacer>
                              <component id="bVal" class="javax.swing.JLabel" binding="bestScoreLbl">
                                <constraints>
                                  <grid row="1" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
                                </constraints>
                                <properties>
                                  <horizontalAlignment value="0"/>
                                  <text value="80%"/>
                                </properties>
                              </component>
                              <component id="bTitle" class="javax.swing.JLabel">
                                <constraints>
                                  <grid row="2" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
                                </constraints>
                                <properties>
                                  <horizontalAlignment value="0"/>
                                  <text value="PERSONAL BEST"/>
                                </properties>
                              </component>
                              <vspacer id="bSpcBot">
                                <constraints>
                                  <grid row="3" column="0" row-span="1" col-span="1" vsize-policy="6" hsize-policy="1" anchor="0" fill="2" indent="0" use-parent-layout="false"/>
                                </constraints>
                              </vspacer>
                            </children>
                          </grid>
                        </children>
                      </grid>
                    </children>
                  </grid>
                  <grid id="footerWrap" binding="footerPanel" layout-manager="BorderLayout" hgap="0" vgap="0">
                    <constraints border-constraint="South"/>
                    <properties>
                      <opaque value="false"/>
                    </properties>
                    <border type="none"/>
                    <children>
                      <grid id="acts" binding="actionsPanel" layout-manager="GridLayoutManager" row-count="1" column-count="3" same-size-horizontally="true" same-size-vertically="false" hgap="15" vgap="0">
                        <margin top="0" left="0" bottom="0" right="0"/>
                        <constraints border-constraint="Center"/>
                        <properties>
                          <opaque value="false"/>
                        </properties>
                        <border type="none"/>
                        <children>
                          <grid id="aw1" binding="actionWrap1" layout-manager="BorderLayout" hgap="0" vgap="0">
                            <constraints>
                              <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="3" hsize-policy="7" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
                            </constraints>
                            <properties>
                              <opaque value="false"/>
                            </properties>
                            <border type="none"/>
                            <children>
                              <component id="revBtn" class="javax.swing.JButton" binding="reviewAnswersBtn">
                                <constraints border-constraint="Center"/>
                                <properties>
                                  <text value="Review Answers"/>
                                </properties>
                              </component>
                            </children>
                          </grid>
                          <grid id="aw2" binding="actionWrap2" layout-manager="BorderLayout" hgap="0" vgap="0">
                            <constraints>
                              <grid row="0" column="1" row-span="1" col-span="1" vsize-policy="3" hsize-policy="7" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
                            </constraints>
                            <properties>
                              <opaque value="false"/>
                            </properties>
                            <border type="none"/>
                            <children>
                              <component id="leadBtn" class="javax.swing.JButton" binding="leaderboardBtn">
                                <constraints border-constraint="Center"/>
                                <properties>
                                  <text value="Leaderboard"/>
                                </properties>
                              </component>
                            </children>
                          </grid>
                          <grid id="aw3" binding="actionWrap3" layout-manager="BorderLayout" hgap="0" vgap="0">
                            <constraints>
                              <grid row="0" column="2" row-span="1" col-span="1" vsize-policy="3" hsize-policy="7" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
                            </constraints>
                            <properties>
                              <opaque value="false"/>
                            </properties>
                            <border type="none"/>
                            <children>
                              <component id="tryBtn" class="javax.swing.JButton" binding="tryAgainBtn">
                                <constraints border-constraint="Center"/>
                                <properties>
                                  <text value="Try Again"/>
                                </properties>
                              </component>
                            </children>
                          </grid>
                        </children>
                      </grid>
                    </children>
                  </grid>
                </children>
              </grid>
            </children>
          </grid>
        </children>
      </grid>
    </children>
  </grid>
</form>
