<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="com.flipit.ui.panels.QuizPanel">
  <grid id="27dc6" binding="root" layout-manager="CardLayout" hgap="0" vgap="0">
    <constraints>
      <xy x="20" y="20" width="800" height="600"/>
    </constraints>
    <properties>
      <opaque value="false"/>
    </properties>
    <border type="none"/>
    <children>
      <grid id="1a2b" binding="quizContainer" layout-manager="BorderLayout" hgap="0" vgap="0">
        <constraints>
          <card name="QUIZ"/>
        </constraints>
        <properties>
          <opaque value="false"/>
        </properties>
        <border type="none"/>
        <children>
          <grid id="3c4d" layout-manager="BorderLayout" hgap="0" vgap="0">
            <constraints border-constraint="North"/>
            <properties>
              <opaque value="false"/>
            </properties>
            <border type="none"/>
            <children>
              <component id="5e6f" class="javax.swing.JButton" binding="backBtn">
                <constraints border-constraint="North"/>
                <properties>
                  <horizontalAlignment value="2"/>
                  <text value="← Back"/>
                </properties>
              </component>
              <grid id="7g8h" layout-manager="BorderLayout" hgap="0" vgap="0">
                <constraints border-constraint="Center"/>
                <properties>
                  <opaque value="false"/>
                </properties>
                <border type="none"/>
                <children>
                  <component id="9i0j" class="javax.swing.JLabel" binding="deckNameLbl">
                    <constraints border-constraint="West"/>
                    <properties>
                      <text value="Deck Name"/>
                    </properties>
                  </component>
                  <component id="a1b2" class="javax.swing.JLabel" binding="counterLbl">
                    <constraints border-constraint="East"/>
                    <properties>
                      <text value="Card 1 of 10"/>
                    </properties>
                  </component>
                </children>
              </grid>
              <component id="c3d4" class="javax.swing.JProgressBar" binding="progressBar">
                <constraints border-constraint="South"/>
                <properties/>
              </component>
            </children>
          </grid>
          <grid id="e5f6" binding="bodyPanel" layout-manager="BorderLayout" hgap="0" vgap="0">
            <constraints border-constraint="Center"/>
            <properties>
              <opaque value="false"/>
            </properties>
            <border type="none"/>
            <children>
              <grid id="g7h8" binding="qCard" layout-manager="BorderLayout" hgap="0" vgap="0">
                <constraints border-constraint="North"/>
                <properties>
                  <opaque value="false"/>
                </properties>
                <border type="none"/>
                <children>
                  <grid id="qHead" layout-manager="BorderLayout" hgap="0" vgap="0">
                    <constraints border-constraint="North"/>
                    <properties>
                      <opaque value="false"/>
                    </properties>
                    <border type="none"/>
                    <children>
                      <component id="i9j0" class="javax.swing.JLabel" binding="questionNumLbl">
                        <constraints border-constraint="Center"/>
                        <properties>
                          <horizontalAlignment value="0"/>
                          <text value="QUESTION 1"/>
                        </properties>
                      </component>
                      <component id="12eb" class="javax.swing.JToggleButton" binding="ttsToggleBtn">
                        <constraints border-constraint="West"/>
                        <properties>
                          <text value=""/>
                        </properties>
                      </component>
                    </children>
                  </grid>
                  <component id="k1l2" class="javax.swing.JLabel" binding="questionLbl">
                    <constraints border-constraint="Center"/>
                    <properties>
                      <horizontalAlignment value="0"/>
                      <text value="Question Text"/>
                    </properties>
                  </component>
                  <component id="3eed5" class="javax.swing.JLabel" binding="questionStatusLbl">
                    <constraints border-constraint="South"/>
                    <properties>
                      <horizontalAlignment value="0"/>
                      <text value=" "/>
                    </properties>
                  </component>
                </children>
              </grid>
              <grid id="m3n4" binding="optionsGridPanel" layout-manager="GridLayoutManager" row-count="2" column-count="2" same-size-horizontally="false" same-size-vertically="false" hgap="15" vgap="15">
                <margin top="0" left="0" bottom="0" right="0"/>
                <constraints border-constraint="Center"/>
                <properties>
                  <opaque value="false"/>
                </properties>
                <border type="none"/>
                <children>
                  <grid id="o5p6" binding="optionPanelA" layout-manager="BorderLayout" hgap="0" vgap="0">
                    <constraints>
                      <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
                    </constraints>
                    <properties>
                      <opaque value="false"/>
                    </properties>
                    <border type="none"/>
                    <children>
                      <grid id="q7r8" binding="badgePanelA" layout-manager="GridBagLayout">
                        <constraints border-constraint="West"/>
                        <properties>
                          <opaque value="false"/>
                        </properties>
                        <border type="none"/>
                        <children>
                          <component id="s9t0" class="javax.swing.JLabel" binding="badgeA">
                            <constraints>
                              <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="0" fill="0" indent="0" use-parent-layout="false"/>
                              <gridbag weightx="0.0" weighty="0.0"/>
                            </constraints>
                            <properties>
                              <text value="A"/>
                            </properties>
                          </component>
                        </children>
                      </grid>
                      <component id="u1v2" class="javax.swing.JLabel" binding="textA">
                        <constraints border-constraint="Center"/>
                        <properties>
                          <text value="Option A Text"/>
                        </properties>
                      </component>
                    </children>
                  </grid>
                  <grid id="w3x4" binding="optionPanelB" layout-manager="BorderLayout" hgap="0" vgap="0">
                    <constraints>
                      <grid row="0" column="1" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
                    </constraints>
                    <properties>
                      <opaque value="false"/>
                    </properties>
                    <border type="none"/>
                    <children>
                      <grid id="y5z6" binding="badgePanelB" layout-manager="GridBagLayout">
                        <constraints border-constraint="West"/>
                        <properties>
                          <opaque value="false"/>
                        </properties>
                        <border type="none"/>
                        <children>
                          <component id="a7b8" class="javax.swing.JLabel" binding="badgeB">
                            <constraints>
                              <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="0" fill="0" indent="0" use-parent-layout="false"/>
                              <gridbag weightx="0.0" weighty="0.0"/>
                            </constraints>
                            <properties>
                              <text value="B"/>
                            </properties>
                          </component>
                        </children>
                      </grid>
                      <component id="c9d0" class="javax.swing.JLabel" binding="textB">
                        <constraints border-constraint="Center"/>
                        <properties>
                          <text value="Option B Text"/>
                        </properties>
                      </component>
                    </children>
                  </grid>
                  <grid id="e1f2" binding="optionPanelC" layout-manager="BorderLayout" hgap="0" vgap="0">
                    <constraints>
                      <grid row="1" column="0" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
                    </constraints>
                    <properties>
                      <opaque value="false"/>
                    </properties>
                    <border type="none"/>
                    <children>
                      <grid id="g3h4" binding="badgePanelC" layout-manager="GridBagLayout">
                        <constraints border-constraint="West"/>
                        <properties>
                          <opaque value="false"/>
                        </properties>
                        <border type="none"/>
                        <children>
                          <component id="i5j6" class="javax.swing.JLabel" binding="badgeC">
                            <constraints>
                              <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="0" fill="0" indent="0" use-parent-layout="false"/>
                              <gridbag weightx="0.0" weighty="0.0"/>
                            </constraints>
                            <properties>
                              <text value="C"/>
                            </properties>
                          </component>
                        </children>
                      </grid>
                      <component id="k7l8" class="javax.swing.JLabel" binding="textC">
                        <constraints border-constraint="Center"/>
                        <properties>
                          <text value="Option C Text"/>
                        </properties>
                      </component>
                    </children>
                  </grid>
                  <grid id="m9n0" binding="optionPanelD" layout-manager="BorderLayout" hgap="0" vgap="0">
                    <constraints>
                      <grid row="1" column="1" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
                    </constraints>
                    <properties>
                      <opaque value="false"/>
                    </properties>
                    <border type="none"/>
                    <children>
                      <grid id="o1p2" binding="badgePanelD" layout-manager="GridBagLayout">
                        <constraints border-constraint="West"/>
                        <properties>
                          <opaque value="false"/>
                        </properties>
                        <border type="none"/>
                        <children>
                          <component id="q3r4" class="javax.swing.JLabel" binding="badgeD">
                            <constraints>
                              <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="0" fill="0" indent="0" use-parent-layout="false"/>
                              <gridbag weightx="0.0" weighty="0.0"/>
                            </constraints>
                            <properties>
                              <text value="D"/>
                            </properties>
                          </component>
                        </children>
                      </grid>
                      <component id="s5t6" class="javax.swing.JLabel" binding="textD">
                        <constraints border-constraint="Center"/>
                        <properties>
                          <text value="Option D Text"/>
                        </properties>
                      </component>
                    </children>
                  </grid>
                </children>
              </grid>
            </children>
          </grid>
          <grid id="u7v8" layout-manager="BorderLayout" hgap="0" vgap="0">
            <constraints border-constraint="South"/>
            <properties>
              <opaque value="false"/>
            </properties>
            <border type="none"/>
            <children>
              <component id="btnPrv" class="javax.swing.JButton" binding="prevBtn">
                <constraints border-constraint="West"/>
                <properties>
                  <text value="← Prev"/>
                </properties>
              </component>
              <grid id="cntAct" layout-manager="FlowLayout" hgap="0" vgap="0" flow-align="1">
                <constraints border-constraint="Center"/>
                <properties>
                  <opaque value="false"/>
                </properties>
                <border type="none"/>
                <children>
                  <component id="w9x0" class="javax.swing.JButton" binding="skipBtn">
                    <constraints/>
                    <properties>
                      <text value="Skip"/>
                    </properties>
                  </component>
                  <component id="y1z2" class="javax.swing.JButton" binding="submitBtn">
                    <constraints/>
                    <properties>
                      <text value="Submit Answer"/>
                    </properties>
                  </component>
                </children>
              </grid>
              <component id="btnNxt" class="javax.swing.JButton" binding="nextBtn">
                <constraints border-constraint="East"/>
                <properties>
                  <text value="Next →"/>
                </properties>
              </component>
            </children>
          </grid>
        </children>
      </grid>
    </children>
  </grid>
</form>
