<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="com.flipit.ui.panels.LeaderboardPanel">
  <grid id="27dc6" binding="root" layout-manager="BorderLayout" hgap="0" vgap="0">
    <constraints>
      <xy x="20" y="20" width="800" height="600"/>
    </constraints>
    <properties>
      <opaque value="false"/>
    </properties>
    <border type="empty"/>
    <children>
      <grid id="topBar" layout-manager="BorderLayout" hgap="0" vgap="0">
        <constraints border-constraint="North"/>
        <properties>
          <opaque value="false"/>
        </properties>
        <border type="empty">
          <size top="0" left="0" bottom="25" right="0"/>
        </border>
        <children>
          <component id="back" class="javax.swing.JButton" binding="backBtn">
            <constraints border-constraint="West"/>
            <properties>
              <text value="Back"/>
            </properties>
          </component>
        </children>
      </grid>
      <grid id="headerContentWrap" layout-manager="BorderLayout" hgap="0" vgap="0">
        <constraints border-constraint="Center"/>
        <properties>
          <opaque value="false"/>
        </properties>
        <border type="none"/>
        <children>
          <grid id="headerSub" layout-manager="BorderLayout" hgap="0" vgap="0">
            <constraints border-constraint="North"/>
            <properties>
              <opaque value="false"/>
            </properties>
            <border type="empty">
              <size top="0" left="5" bottom="15" right="5"/>
            </border>
            <children>
              <component id="hdrTitle" class="javax.swing.JLabel" binding="headerTitleLbl">
                <constraints border-constraint="West"/>
                <properties>
                  <text value="LEADERBOARD"/>
                </properties>
              </component>
              <component id="deckPill" class="javax.swing.JLabel" binding="deckBadgeLbl">
                <constraints border-constraint="East"/>
                <properties>
                  <text value="DECK NAME"/>
                </properties>
              </component>
            </children>
          </grid>
          <scrollpane id="scroll" binding="scrollPane">
            <constraints border-constraint="Center"/>
            <properties>
              <opaque value="false"/>
            </properties>
            <border type="none"/>
            <children>
              <grid id="alignWrap" binding="listAlignmentWrapper" layout-manager="BorderLayout" hgap="0" vgap="0">
                <constraints/>
                <properties>
                  <opaque value="false"/>
                </properties>
                <border type="empty">
                  <size top="0" left="2" bottom="10" right="2"/>
                </border>
                <children/>
              </grid>
            </children>
          </scrollpane>
        </children>
      </grid>
    </children>
  </grid>
</form>
