<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="com.flipit.ui.dialogs.GenerationDialog">
  <grid id="27dc6" binding="root" layout-manager="CardLayout" hgap="0" vgap="0">
    <constraints>
      <xy x="20" y="20" width="515" height="362"/>
    </constraints>
    <properties>
      <preferredSize width="450" height="320"/>
    </properties>
    <border type="none"/>
    <children>
      <grid id="1a2b" binding="settingsCard" layout-manager="GridBagLayout">
        <constraints>
          <card name="SETTINGS"/>
        </constraints>
        <properties>
          <background color="-1"/>
        </properties>
        <border type="empty">
          <size top="24" left="32" bottom="24" right="32"/>
        </border>
        <children>
          <component id="3c4d" class="javax.swing.JLabel" binding="titleLbl">
            <constraints>
              <grid row="0" column="0" row-span="1" col-span="2" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
              <gridbag top="0" left="0" bottom="4" right="0" weightx="1.0" weighty="0.0"/>
            </constraints>
            <properties>
              <text value="Generate Flashcards"/>
            </properties>
          </component>
          <component id="5e6f" class="javax.swing.JLabel" binding="fileLbl">
            <constraints>
              <grid row="1" column="0" row-span="1" col-span="2" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
              <gridbag top="0" left="0" bottom="24" right="0" weightx="1.0" weighty="0.0"/>
            </constraints>
            <properties>
              <text value="Selected File: "/>
            </properties>
          </component>
          <component id="7g8h" class="javax.swing.JLabel" binding="deckTitleLbl">
            <constraints>
              <grid row="2" column="0" row-span="1" col-span="2" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
              <gridbag top="0" left="0" bottom="6" right="0" weightx="1.0" weighty="0.0"/>
            </constraints>
            <properties>
              <text value="Deck Title"/>
            </properties>
          </component>
          <component id="9i0j" class="javax.swing.JTextField" binding="titleField">
            <constraints>
              <grid row="3" column="0" row-span="1" col-span="2" vsize-policy="0" hsize-policy="6" anchor="8" fill="1" indent="0" use-parent-layout="false"/>
              <gridbag top="0" left="0" bottom="16" right="0" weightx="1.0" weighty="0.0"/>
            </constraints>
            <properties>
              <preferredSize width="-1" height="36"/>
            </properties>
          </component>
          <component id="a1b2" class="javax.swing.JLabel" binding="amountLbl">
            <constraints>
              <grid row="4" column="0" row-span="1" col-span="2" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
              <gridbag top="0" left="0" bottom="6" right="0" weightx="1.0" weighty="0.0"/>
            </constraints>
            <properties>
              <text value="Number of Cards to Generate"/>
            </properties>
          </component>
          <component id="c3d4" class="javax.swing.JSpinner" binding="amountSpinner">
            <constraints>
              <grid row="5" column="0" row-span="1" col-span="2" vsize-policy="0" hsize-policy="6" anchor="8" fill="1" indent="0" use-parent-layout="false"/>
              <gridbag top="0" left="0" bottom="24" right="0" weightx="1.0" weighty="0.0"/>
            </constraints>
            <properties>
              <preferredSize width="-1" height="36"/>
            </properties>
          </component>
          <grid id="e5f6" layout-manager="FlowLayout" hgap="12" vgap="0" flow-align="2">
            <constraints>
              <grid row="6" column="0" row-span="1" col-span="2" vsize-policy="3" hsize-policy="3" anchor="4" fill="0" indent="0" use-parent-layout="false"/>
              <gridbag weightx="1.0" weighty="1.0"/>
            </constraints>
            <properties>
              <opaque value="false"/>
            </properties>
            <border type="none"/>
            <children>
              <component id="g7h8" class="javax.swing.JButton" binding="cancelBtn">
                <constraints/>
                <properties>
                  <preferredSize width="100" height="36"/>
                  <text value="Cancel"/>
                </properties>
              </component>
              <component id="i9j0" class="javax.swing.JButton" binding="generateBtn">
                <constraints/>
                <properties>
                  <preferredSize width="120" height="36"/>
                  <text value="Generate"/>
                </properties>
              </component>
            </children>
          </grid>
        </children>
      </grid>
      <grid id="k1l2" binding="loadingCard" layout-manager="GridBagLayout">
        <constraints>
          <card name="LOADING"/>
        </constraints>
        <properties>
          <background color="-1"/>
        </properties>
        <border type="empty">
          <size top="40" left="40" bottom="40" right="40"/>
        </border>
        <children>
          <grid id="m3n4" binding="spinnerPanel" layout-manager="BorderLayout" hgap="0" vgap="0">
            <constraints>
              <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="0" fill="0" indent="0" use-parent-layout="false"/>
              <gridbag top="0" left="0" bottom="24" right="0" weightx="1.0" weighty="0.0"/>
            </constraints>
            <properties>
              <minimumSize width="80" height="80"/>
              <opaque value="false"/>
              <preferredSize width="80" height="80"/>
            </properties>
            <border type="none"/>
            <children/>
          </grid>
          <component id="q7r8" class="javax.swing.JLabel" binding="loadingSub">
            <constraints>
              <grid row="1" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="0" fill="0" indent="0" use-parent-layout="false"/>
              <gridbag weightx="1.0" weighty="0.0"/>
            </constraints>
            <properties>
              <horizontalAlignment value="0"/>
              <text value="Initializing..."/>
            </properties>
          </component>
        </children>
      </grid>
    </children>
  </grid>
</form>
