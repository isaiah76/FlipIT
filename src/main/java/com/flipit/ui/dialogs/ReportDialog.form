<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="com.flipit.ui.dialogs.ReportDialog">
  <grid id="cbd77" row-count="3" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1" binding="contentPane">
    <margin top="0" left="0" bottom="0" right="0"/>
    <constraints>
      <xy x="48" y="54" width="420" height="280"/>
      <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3"/>
    </constraints>
    <properties/>
    <border type="none"/>
    <children>
      <grid id="94766" row-count="1" column-count="2" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
        <margin top="10" left="0" bottom="0" right="0"/>
        <constraints>
          <xy x="20" y="232" width="380" height="23"/>
          <grid row="2" column="0" row-span="1" col-span="1" vsize-policy="1" hsize-policy="3" anchor="0" fill="3"/>
        </constraints>
        <properties/>
        <border type="none"/>
        <children>
          <hspacer id="98af6">
            <constraints>
              <xy x="0" y="6" width="230" height="11"/>
              <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="1" hsize-policy="6" anchor="0" fill="1"/>
            </constraints>
          </hspacer>
          <grid id="9538f" row-count="1" column-count="2" same-size-horizontally="true" same-size-vertically="false" hgap="8" vgap="-1">
            <margin top="0" left="0" bottom="0" right="0"/>
            <constraints>
              <xy x="240" y="0" width="140" height="23"/>
              <grid row="0" column="1" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3"/>
            </constraints>
            <properties/>
            <border type="none"/>
            <children>
              <component id="5723f" class="javax.swing.JButton" binding="buttonCancel">
                <constraints>
                  <xy x="0" y="0" width="65" height="23"/>
                  <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1"/>
                </constraints>
                <properties>
                  <text value="Cancel"/>
                </properties>
              </component>
              <component id="e7465" class="javax.swing.JButton" binding="buttonOK">
                <constraints>
                  <xy x="75" y="0" width="65" height="23"/>
                  <grid row="0" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1"/>
                </constraints>
                <properties>
                  <text value="Submit"/>
                </properties>
              </component>
            </children>
          </grid>
        </children>
      </grid>
      <grid id="e3588" row-count="2" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="8">
        <margin top="0" left="0" bottom="0" right="0"/>
        <constraints>
          <xy x="20" y="15" width="380" height="190"/>
          <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3"/>
        </constraints>
        <properties/>
        <border type="none"/>
        <children>
          <component id="lbl1" class="javax.swing.JLabel" binding="messageLabel">
            <constraints>
              <xy x="0" y="0" width="380" height="16"/>
              <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0"/>
            </constraints>
            <properties>
              <text value="Reason for reporting:"/>
            </properties>
          </component>
          <scrollpane id="sp1" binding="scrollPane">
            <constraints>
              <xy x="0" y="24" width="380" height="166"/>
              <grid row="1" column="0" row-span="1" col-span="1" vsize-policy="7" hsize-policy="7" anchor="0" fill="3"/>
            </constraints>
            <properties/>
            <border type="none"/>
            <children>
              <component id="reportArea" class="javax.swing.JTextArea" binding="reportArea">
                <constraints/>
                <properties/>
              </component>
            </children>
          </scrollpane>
        </children>
      </grid>
      <vspacer id="spacer1">
        <constraints>
          <xy x="20" y="215" width="380" height="11"/>
          <grid row="1" column="0" row-span="1" col-span="1" vsize-policy="6" hsize-policy="1" anchor="0" fill="2"/>
        </constraints>
      </vspacer>
    </children>
  </grid>
</form>
