<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="com.flipit.ui.dialogs.InfoDialog">
  <grid id="cbd77" row-count="2" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1" binding="contentPane">
    <margin top="0" left="0" bottom="0" right="0"/>
    <constraints>
      <xy x="48" y="54" width="350" height="140"/>
      <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3"/>
    </constraints>
    <properties>
      <background color="-1"/>
    </properties>
    <border type="none"/>
    <children>
      <grid id="94766" row-count="1" column-count="2" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
        <margin top="10" left="0" bottom="0" right="0"/>
        <constraints>
          <xy x="20" y="102" width="310" height="23"/>
          <grid row="1" column="0" row-span="1" col-span="1" vsize-policy="1" hsize-policy="3" anchor="0" fill="3"/>
        </constraints>
        <properties>
          <background color="-1"/>
        </properties>
        <border type="none"/>
        <children>
          <hspacer id="98af6">
            <constraints>
              <xy x="0" y="6" width="235" height="11"/>
              <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="1" hsize-policy="6" anchor="0" fill="1"/>
            </constraints>
          </hspacer>
          <component id="e7465" class="javax.swing.JButton" binding="buttonOK">
            <constraints>
              <xy x="235" y="0" width="75" height="23"/>
              <grid row="0" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1"/>
            </constraints>
            <properties>
              <text value="OK"/>
            </properties>
          </component>
        </children>
      </grid>
      <component id="lblMsg" class="javax.swing.JLabel" binding="messageLabel">
        <constraints>
          <xy x="20" y="20" width="310" height="72"/>
          <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3"/>
        </constraints>
        <properties>
          <horizontalAlignment value="2"/>
          <text value="Information message here."/>
        </properties>
      </component>
    </children>
  </grid>
</form>
